{
  "name": "skill-marketplace-desktop",
  "private": true,
  "version": "0.2.0",
  "description": "通用 Agent 技能的发现、安装与管理桌面应用。",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "web:dev": "vite",
    "build": "tsc && vite build",
    "web:build": "tsc && vite build",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "compile": "npm run check-types && npm run lint && npm run web:build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "npm exec tauri dev -- --config src-tauri/tauri.conf.json",
    "tauri:build": "npm exec tauri build -- --config src-tauri/tauri.conf.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-store": "^2.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.52.0",
    "vite": "^7.0.4"
  }
}
