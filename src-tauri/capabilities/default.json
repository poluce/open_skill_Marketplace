{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-confirm",
    "dialog:allow-open",
    "clipboard-manager:allow-write-text",
    "store:default",
    "opener:allow-default-urls",
    "opener:allow-open-path"
  ]
}
